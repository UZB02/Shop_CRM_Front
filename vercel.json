{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://shopcrmsystem-production.up.railway.app/api/:path*"
    },
    {
      "source": "/media/:path*",
      "destination": "https://shopcrmsystem-production.up.railway.app/media/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ],
  "trailingSlash": false
}
